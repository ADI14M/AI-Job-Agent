# --- DATABASE ---
# Option A: SQLite (default, zero setup, recommended for local use)
DATABASE_URL=sqlite:///./jobagent.db

# Option B: PostgreSQL (uncomment for production/multi-user)
# DATABASE_URL=postgresql://user:password@localhost:5432/jobagent

# --- SECURITY ---
SECRET_KEY=your_secure_random_secret_here

# ════════════════════════════════════════════════
#   LLM PROVIDER — choose one
# ════════════════════════════════════════════════

# ── Option A: Ollama Local (DEFAULT — free, offline, M5 optimised)
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
FAST_LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

# ── Option B: OpenAI Cloud (comment Option A, uncomment below)
# USE_OLLAMA=false
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- CHROMADB ---
CHROMA_PATH=./chroma_db
